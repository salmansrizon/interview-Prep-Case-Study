      "frameId": "e0254",
      "roundness": null,
      "text": "import numpy as np\ndf['month_sin'] = np.sin(2 * np.pi * df['month'] / 12)\ndf['month_cos'] = np.cos(2 * np.pi * df['month'] / 12)",
