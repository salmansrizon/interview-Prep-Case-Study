      "link": null,
      "locked": false,
      "frameId": "e0482",
      "roundness": null,
      "text": "spend_q67 = df['Amount_spent'].quantile(0.67)   # 1800",
      "fontSize": 14,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "middle",
      "fontWeight": "normal",
