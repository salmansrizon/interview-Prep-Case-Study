{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CleanDataRecord",
  "description": "Schema for validated clean data records. Enforces structure so downstream models do not receive garbage.",
  "type": "object",
  "required": ["id", "text", "status", "timestamp"],
  "properties": {
    "id": {
      "type": "integer",
      "description": "Unique record identifier"
    },
    "text": {
      "type": "string",
      "minLength": 5,
      "maxLength": 500,
      "description": "Cleaned text content"
    },
    "status": {
      "type": "string",
      "enum": ["active", "pending", "archived"],
      "description": "Record lifecycle status"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp"
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Optional model confidence score"
    }
  }
}
